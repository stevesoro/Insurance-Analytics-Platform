# -----------------------------------------------------------------------------

.vscode/*
!.vscode/settings.json

# -----------------------------------------------------------------------------

# Operating System

# -----------------------------------------------------------------------------

.DS_Store
Thumbs.db
desktop.ini

# -----------------------------------------------------------------------------

